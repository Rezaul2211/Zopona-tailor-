rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Products collection: public read, write by authenticated users or public during setup
    match /products/{productId} {
      allow read: if true;
      allow write: if true;
    }

    // Orders collection: public read (for order tracker by ID) and create/update
    match /orders/{orderId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // Users collection: user profile data
    match /users/{userId} {
      allow read: if true;
      allow write: if true;
    }

    // Measurement profiles collection
    match /measurementProfiles/{profileId} {
      allow read: if true;
      allow write: if true;
    }

    // Default fallback
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
